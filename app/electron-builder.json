{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.docker-manager.app",
  "productName": "Docker Manager",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "electron/**/*.js",
    "!node_modules/**/*"
  ],
  "extraResources": [
    {
      "from": "../api/bin",
      "to": "api",
      "filter": ["**/*"]
    }
  ],
  "mac": {
    "category": "public.app-category.developer-tools",
    "target": ["dmg", "zip"],
    "icon": "build/icon.icns"
  },
  "win": {
    "target": ["nsis", "portable"],
    "icon": "build/icon.ico"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Development",
    "icon": "build/icon.png",
    "maintainer": "IzuCas <izucas@users.noreply.github.com>",
    "executableArgs": ["--no-sandbox", "--disable-gpu-sandbox"],
    "desktop": {
      "StartupWMClass": "Docker Manager"
    }
  },
  "deb": {
    "depends": ["docker.io"]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
